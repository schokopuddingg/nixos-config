    signal-desktop
    gajim
    ferdium
    element-desktop
    telegram-desktop
    discord
    thunderbird
    
    # Tools / Office
    bitwarden-desktop
    libreoffice
    naps2
    
    # Media
    spotify
    darktable
    rawtherapee
    gimp
    steam
    mastodon
    ardour
    audacity
    
  ];
}
